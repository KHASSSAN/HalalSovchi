# Public Supabase (anon key is safe in client; RLS must protect data)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Только для сервера — НЕ префикс VITE_. В Supabase: Dashboard → Edge Functions → Secrets → TELEGRAM_BOT_TOKEN
# Локально при `supabase functions serve`: supabase secrets set TELEGRAM_BOT_TOKEN=...
# TELEGRAM_BOT_TOKEN=
